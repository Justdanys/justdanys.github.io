<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Daniel Pleskač | Byznys, Management & IT Consulting</title>
    <style>
        :root {
            --primary: #0f172a;       /* Slate 900 - Dark Professional */
            --primary-light: #1d4ed8; /* Royal Blue */
            --accent: #38bdf8;        /* Light Blue */
            --bg-body: #f1f5f9;       /* Light Slate */
            --bg-card: #ffffff;       /* White */
            --text-main: #1e293b;     /* Slate 800 */
            --text-muted: #64748b;    /* Slate 500 */
            --border-color: #e2e8f0;  /* Slate 200 */
            --success: #10b981;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            scroll-behavior: smooth;
        }

        body {
            background-color: var(--bg-body);
            color: var(--text-main);
            line-height: 1.7;
        }

        /* Navigace */
        nav {
            background-color: rgba(15, 23, 42, 0.95);
            backdrop-filter: blur(10px);
            padding: 1.2rem 0;
            position: sticky;
            top: 0;
            z-index: 1000;
            box-shadow: 0 4px 20px rgba(0,0,0,0.1);
        }

        .nav-container {
            max-width: 1200px;
            margin: 0 auto;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 2rem;
        }

        .nav-logo {
            color: white;
            font-weight: 800;
            font-size: 1.4rem;
            text-decoration: none;
            letter-spacing: 0.5px;
        }

        .nav-logo span {
            color: var(--accent);
        }

        .nav-links {
            list-style: none;
            display: flex;
            gap: 2rem;
        }

        .nav-links a {
            color: #cbd5e1;
            text-decoration: none;
            font-size: 0.95rem;
            font-weight: 500;
            transition: color 0.3s;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .nav-links a:hover {
            color: var(--accent);
        }

        /* Hlavička */
        header {
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
            color: white;
            padding: 7rem 2rem 9rem 2rem;
            text-align: center;
            position: relative;
            overflow: hidden;
        }

        header::after {
            content: '';
            position: absolute;
            bottom: -50px;
            left: 0;
            right: 0;
            height: 100px;
            background: var(--bg-body);
            transform: skewY(-2deg);
        }

        header h1 {
            font-size: 4rem;
            font-weight: 900;
            margin-bottom: 1.5rem;
            letter-spacing: -1.5px;
            position: relative;
            z-index: 10;
        }

        header p {
            font-size: 1.3rem;
            color: #94a3b8;
            max-width: 800px;
            margin: 0 auto 2.5rem auto;
            position: relative;
            z-index: 10;
        }

        .btn-cta {
            display: inline-block;
            background-color: var(--primary-light);
            color: white;
            padding: 1rem 2.5rem;
            border-radius: 50px;
            text-decoration: none;
            font-weight: 600;
            font-size: 1.1rem;
            transition: all 0.3s;
            position: relative;
            z-index: 10;
            box-shadow: 0 4px 15px rgba(29, 78, 216, 0.4);
        }

        .btn-cta:hover {
            background-color: #2563eb;
            transform: translateY(-3px);
            box-shadow: 0 8px 25px rgba(29, 78, 216, 0.5);
        }

        .container {
            max-width: 1200px;
            margin: -3rem auto 2rem auto;
            padding: 0 1.5rem;
            position: relative;
            z-index: 10;
        }

        section {
            background: var(--bg-card);
            border-radius: 16px;
            padding: 4rem;
            margin-bottom: 3rem;
            box-shadow: 0 10px 30px -5px rgba(0, 0, 0, 0.05);
            border: 1px solid var(--border-color);
            scroll-margin-top: 6rem;
        }

        .section-title {
            font-size: 2.2rem;
            font-weight: 800;
            color: var(--primary);
            margin-bottom: 3rem;
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .section-title::before {
            content: '';
            display: block;
            width: 6px;
            height: 30px;
            background-color: var(--primary-light);
            border-radius: 3px;
        }

        /* O mně layout */
        .about-content {
            display: grid;
            grid-template-columns: 3fr 2fr;
            gap: 4rem;
            align-items: start;
        }

        .about-text p {
            font-size: 1.15rem;
            color: #475569;
            margin-bottom: 1.5rem;
        }

        .about-stats {
            background-color: #f8fafc;
            padding: 2rem;
            border-radius: 12px;
            border: 1px solid var(--border-color);
        }

        .stat-item {
            margin-bottom: 1.5rem;
            padding-bottom: 1.5rem;
            border-bottom: 1px solid var(--border-color);
        }
        .stat-item:last-child {
            margin-bottom: 0;
            padding-bottom: 0;
            border-bottom: none;
        }
        .stat-item strong {
            display: block;
            color: var(--primary);
            font-size: 1.2rem;
            margin-bottom: 0.3rem;
        }
        .stat-item span {
            color: var(--text-muted);
            font-size: 1rem;
        }

        /* Zkušenosti (Kariéra) - Timeline */
        .timeline {
            position: relative;
            padding-left: 2rem;
        }

        .timeline::before {
            content: '';
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
            width: 3px;
            background-color: #e2e8f0;
            border-radius: 3px;
        }

        .timeline-item {
            position: relative;
            margin-bottom: 3rem;
        }

        .timeline-item:last-child {
            margin-bottom: 0;
        }

        .timeline-item::before {
            content: '';
            position: absolute;
            left: -2.4rem;
            top: 0.3rem;
            width: 16px;
            height: 16px;
            background-color: var(--primary-light);
            border-radius: 50%;
            border: 4px solid var(--bg-card);
            box-shadow: 0 0 0 2px #e2e8f0;
            transition: all 0.3s ease;
        }

        .timeline-item:hover::before {
            background-color: var(--accent);
            transform: scale(1.2);
        }

        .timeline-date {
            display: inline-block;
            background-color: #eff6ff;
            color: var(--primary-light);
            padding: 0.3rem 1rem;
            border-radius: 50px;
            font-size: 0.85rem;
            font-weight: 700;
            margin-bottom: 1rem;
        }

        .timeline-content h3 {
            font-size: 1.5rem;
            color: var(--primary);
            margin-bottom: 0.5rem;
        }

        .timeline-content h4 {
            font-size: 1.1rem;
            color: var(--text-muted);
            font-weight: 500;
            margin-bottom: 1rem;
        }

        .timeline-content p {
            color: #475569;
            margin-bottom: 1rem;
        }

        /* Projekty Grid */
        .projects-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
            gap: 2.5rem;
        }

        .project-card {
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 2.5rem;
            background-color: #f8fafc;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
            z-index: 1;
        }

        .project-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(to bottom right, #ffffff, #f1f5f9);
            z-index: -1;
            transition: opacity 0.3s ease;
            opacity: 0;
        }

        .project-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 15px 35px -5px rgba(0, 0, 0, 0.1);
            border-color: #cbd5e1;
        }

        .project-card:hover::before {
            opacity: 1;
        }

        .project-icon {
            font-size: 2.5rem;
            margin-bottom: 1.5rem;
            display: inline-block;
        }

        .project-card h3 {
            font-size: 1.4rem;
            margin-bottom: 1rem;
            color: var(--primary);
        }

        .project-card p {
            color: var(--text-muted);
            margin-bottom: 1.5rem;
            font-size: 1rem;
        }

        .tags {
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem;
        }

        .tag {
            background-color: #e2e8f0;
            color: #334155;
            font-size: 0.85rem;
            padding: 0.4rem 1rem;
            border-radius: 6px;
            font-weight: 600;
        }

        /* Akademie Grid */
        .study-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 2rem;
        }

        .study-item {
            background: #ffffff;
            padding: 2rem;
            border-radius: 12px;
            border: 1px solid var(--border-color);
            border-top: 4px solid var(--primary-light);
            box-shadow: 0 4px 6px rgba(0,0,0,0.02);
        }

        .study-item h4 {
            color: var(--text-main);
            margin-bottom: 0.5rem;
            font-size: 1.3rem;
        }

        .study-badge {
            display: inline-block;
            font-size: 0.8rem;
            background: #f1f5f9;
            padding: 0.3rem 0.8rem;
            border-radius: 4px;
            color: var(--text-muted);
            margin-bottom: 1rem;
            font-weight: 600;
        }

        /* Kontakt sekce */
        .contact-info {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 2rem;
        }

        .contact-item {
            display: flex;
            align-items: center;
            gap: 1.5rem;
            padding: 2rem;
            background-color: #f8fafc;
            border-radius: 12px;
            border: 1px solid var(--border-color);
            transition: all 0.3s ease;
        }

        .contact-item:hover {
            border-color: var(--primary-light);
            background-color: #ffffff;
            box-shadow: 0 10px 20px rgba(0,0,0,0.05);
        }

        .contact-icon {
            width: 60px;
            height: 60px;
            background-color: #eff6ff;
            color: var(--primary-light);
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.8rem;
        }

        .contact-text h4 {
            font-size: 0.9rem;
            text-transform: uppercase;
            color: var(--text-muted);
            letter-spacing: 1px;
            margin-bottom: 0.3rem;
        }

        .contact-text a {
            font-size: 1.2rem;
            color: var(--primary);
            font-weight: 700;
            text-decoration: none;
        }

        .contact-text a:hover {
            color: var(--primary-light);
        }

        footer {
            background-color: var(--primary);
            color: #94a3b8;
            text-align: center;
            padding: 4rem 2rem;
            font-size: 1rem;
        }

        @media (max-width: 900px) {
            .about-content { grid-template-columns: 1fr; }
            section { padding: 2.5rem; }
        }

        @media (max-width: 768px) {
            header { padding: 6rem 1rem 7rem 1rem; }
            header h1 { font-size: 2.8rem; }
            section { padding: 2rem 1.5rem; }
            .nav-links { display: none; }
        }
    </style>
</head>
